{
  "name": "suraksha-api",
  "type": "http",
  "runtime": "python312",
  "entry": "main.py",
  "memory": 512,
  "timeout": 30,
  "env": {
    "DB_TYPE": "catalyst_datastore",
    "CACHE_TYPE": "catalyst_cache",
    "AI_PROVIDER": "catalyst_quickml"
  },
  "layers": [],
  "dependencies": "requirements.txt",
  "cors": {
    "allow_origins": ["*"],
    "allow_methods": ["GET", "POST", "PUT", "DELETE", "PATCH"],
    "allow_headers": ["*"],
    "allow_credentials": true
  }
}

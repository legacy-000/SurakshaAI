# ── LLM provider slot ─────────────────────────────────────────────
# The app runs fully WITHOUT any of these set: it falls back to a
# deterministic mock/rule-based engine so every feature works offline.
#
# When you are ready to wire a real model (e.g. Zoho Catalyst / OpenAI),
# set LLM_PROVIDER and the matching key below and restart the backend.

# one of: mock | catalyst | openai
LLM_PROVIDER=mock

# --- Catalyst (leave blank for now; app uses mock) ---
CATALYST_API_KEY=
CATALYST_ENDPOINT=
CATALYST_MODEL=

# --- OpenAI (optional alternative) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── App ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./crimeintel.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECRET_KEY=dev-secret-change-me

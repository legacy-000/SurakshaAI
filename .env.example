# ==============================================================================
# SURAKSHA AI - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# --- System Environment ---
ENV=development
DEBUG=true
SECRET_KEY=generate-a-secure-32-byte-hex-string-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Backend Configuration ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database Configuration (PostgreSQL + PostGIS) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=suraksha_admin
DB_PASSWORD=suraksha_secure_pass
DB_NAME=suraksha_db
DB_SSL_MODE=disable

# --- Redis Configuration (Cache & Celery & LangGraph State) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass
REDIS_DB=0

# --- AI Engine & LLM Configuration ---
# Models
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
LLM_PROVIDER=openai # openai, anthropic, ollama, local
LLM_MODEL_NAME=gpt-4o

# API Keys (Do not check keys into git)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langchain-api-key
LANGCHAIN_PROJECT=suraksha-ai

# Vector DB
FAISS_INDEX_PATH=./ai_engine/rag/faiss_index

# --- Logging & Analytics ---
LOG_LEVEL=INFO
CHAT_LOG_PATH=./logs/chat.log
ANALYTICS_LOG_PATH=./logs/analytics.log
PREDICTION_LOG_PATH=./logs/prediction.log
NETWORK_LOG_PATH=./logs/network.log
REPORT_LOG_PATH=./logs/report.log

# --- Frontend Configuration ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
NEXT_PUBLIC_LEAFLET_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ==============================================================================
# SURAKSHA AI - CATALYST ENVIRONMENT CONFIGURATION
# ==============================================================================

# --- System Environment ---
ENV=development
DEBUG=true
SECRET_KEY=generate-a-secure-32-byte-hex-string-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Catalyst Configuration ---
CATALYST_APP_ID=your-catalyst-app-id
CATALYST_APP_NAME=suraksha-ai
CATALYST_ORG_ID=your-org-id
CATALYST_DC=your-datacenter (e.g., in, us, eu)
CATALYST_AUTH_TOKEN=your-catalyst-auth-token

# --- Backend Configuration ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Data Store Configuration (Catalyst NoSQL) ---
DB_TYPE=catalyst_datastore
CATALYST_PROJECT_ID=your-project-id

# --- Cache Configuration (Catalyst Cache) ---
CACHE_TYPE=catalyst_cache
CATALYST_CACHE_SEGMENT=session_store

# --- AI Engine & LLM Configuration (Catalyst QuickML) ---
AI_PROVIDER=catalyst_quickml
QUICKML_KB_ID=crime_documents
QUICKML_MODEL_TYPE=text_generation

# --- Zia Services ---
ZIA_OCR_ENABLED=true
ZIA_OBJECT_DETECTION_ENABLED=true
ZIA_BARCODE_ENABLED=true

# --- Stratus Object Storage ---
STRATUS_BUCKET=evidence_files

# --- Logging & Analytics ---
LOG_LEVEL=INFO

# --- Frontend Configuration ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_CATALYST_ENV=development
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
NEXT_PUBLIC_LEAFLET_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

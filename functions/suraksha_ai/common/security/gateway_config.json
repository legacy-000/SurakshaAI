{
  "gateway": {
    "routes": [
      { "path": "/api/chat", "methods": ["POST"], "auth_required": true, "rate_limit": 60 },
      { "path": "/api/analytics", "methods": ["GET"], "auth_required": true, "rate_limit": 120 },
      { "path": "/api/network", "methods": ["GET"], "auth_required": true, "rate_limit": 60 },
      { "path": "/api/offender", "methods": ["GET", "POST"], "auth_required": true, "rate_limit": 60 },
      { "path": "/api/forecast", "methods": ["GET"], "auth_required": true, "rate_limit": 30 },
      { "path": "/api/alerts", "methods": ["GET", "POST"], "auth_required": true, "rate_limit": 60 },
      { "path": "/api/command", "methods": ["POST"], "auth_required": true, "rate_limit": 30 },
      { "path": "/api/auth/login", "methods": ["POST"], "auth_required": false, "rate_limit": 10 },
      { "path": "/api/health", "methods": ["GET"], "auth_required": false, "rate_limit": 300 }
    ],
    "throttling": { "default_rate": 60, "burst": 20, "window_seconds": 60 }
  }
}

{
  "deployment": {
    "name": "suraksha-api",
    "stack": "python_3_12",
    "type": "advancedio",
    "memory": 512,
    "timeout": 30,
    "env_variables": {
      "DB_TYPE": "catalyst_datastore",
      "CACHE_TYPE": "catalyst_cache",
      "AI_PROVIDER": "catalyst_quickml"
    }
  },
  "execution": {
    "main": "main.py"
  },
  "dependencies": {
    "file": "requirements.txt"
  },
  "cors": {
    "allow_origins": ["*"],
    "allow_methods": ["GET", "POST", "PUT", "DELETE", "PATCH"],
    "allow_headers": ["*"],
    "allow_credentials": true
  }
}

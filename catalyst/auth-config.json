{
  "provider": "catalyst_authentication",
  "roles": [
    { "id": 1, "name": "Investigator", "description": "Can view case data, network, workspace" },
    { "id": 2, "name": "Analyst", "description": "Can view analytics, trends, forecasts" },
    { "id": 3, "name": "Supervisor", "description": "Can view alerts and manage teams" },
    { "id": 4, "name": "Policymaker", "description": "Can view aggregated statistics" },
    { "id": 5, "name": "System Administrator", "description": "Full system access" }
  ],
  "session_timeout_minutes": 60,
  "password_policy": {
    "min_length": 8,
    "require_special_char": true,
    "require_number": true
  }
}

{
  "project_id": "ksp-suraksha-ai",
  "project_name": "Suraksha AI",
  "description": "KSP Intelligent Conversational AI & Crime Analytics Platform",
  "environment": "development",
  "services": {
    "datastore": "ksp-dev-datastore",
    "nosql": "ksp-dev-conversation-nosql",
    "stratus": "ksp-dev-report-stratus",
    "cache": "ksp-dev-query-cache",
    "quickml": {
      "model_id": "quickml-llama-3.1-70b",
      "config": {
        "temperature_nl2sql": 0.1,
        "temperature_summary": 0.3,
        "max_tokens": 4096
      }
    },
    "rag_kb": {
      "schema": "ksp-dev-rag-kb-schema",
      "examples": "ksp-dev-rag-kb-examples"
    },
    "zia": {
      "stt_locales": ["en-IN", "kn-IN"],
      "tts_voice": "en-IN-Standard-A"
    },
    "smartbrowz": {
      "template": "report_template.html"
    },
    "cron": {
      "forecast": "0 6 * * *",
      "alerts": "0 7 * * *"
    }
  }
}

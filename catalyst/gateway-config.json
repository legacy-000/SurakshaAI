{
  "routes": [
    {
      "path": "/chatbot",
      "method": "POST",
      "auth_required": false,
      "rate_limit": 60,
      "target": "chatbot"
    },
    {
      "path": "/api/**",
      "method": "ALL",
      "auth_required": false,
      "rate_limit": 60,
      "target": "suraksha_ai"
    },
    {
      "path": "/auth/**",
      "method": "ALL",
      "auth_required": false,
      "rate_limit": 20
    },
    {
      "path": "/chat/**",
      "method": "ALL",
      "auth_required": true,
      "rate_limit": 60
    },
    {
      "path": "/analytics/**",
      "method": "GET",
      "auth_required": true,
      "rate_limit": 30
    },
    {
      "path": "/network/**",
      "method": "ALL",
      "auth_required": true,
      "rate_limit": 20
    },
    {
      "path": "/offender/**",
      "method": "GET",
      "auth_required": true,
      "rate_limit": 30
    },
    {
      "path": "/cases/**",
      "method": "GET",
      "auth_required": true,
      "rate_limit": 60
    },
    {
      "path": "/investigations/**",
      "method": "ALL",
      "auth_required": true,
      "rate_limit": 30
    },
    {
      "path": "/forecasts/**",
      "method": "GET",
      "auth_required": true,
      "rate_limit": 20
    },
    {
      "path": "/alerts/**",
      "method": "ALL",
      "auth_required": true,
      "rate_limit": 20
    },
    {
      "path": "/export/**",
      "method": "GET",
      "auth_required": true,
      "rate_limit": 10
    },
    {
      "path": "/financial/**",
      "method": "GET",
      "auth_required": true,
      "rate_limit": 20
    },
    {
      "path": "/audit/**",
      "method": "GET",
      "auth_required": true,
      "rate_limit": 10
    },
    {
      "path": "/health",
      "method": "GET",
      "auth_required": false,
      "rate_limit": 100
    }
  ],
  "cors": {
    "allowed_origins": [
      "*"
    ],
    "allowed_methods": [
      "GET",
      "POST",
      "PUT",
      "DELETE"
    ],
    "allowed_headers": [
      "Authorization",
      "Content-Type"
    ]
  }
}